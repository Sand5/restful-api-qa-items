{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": ["cpuModel", "price"],
      "additionalProperties": false,
      "properties": {
        "cpuModel": {
          "type": "string"
        },
        "price": {
          "type": "number"
        }
      }
    }
  }
}